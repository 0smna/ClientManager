@{
    ViewData["Title"] = "Inicio";
}

<div class="container-fluid p-0">

    <!-- HERO SECTION -->
    <div class="bg-dark text-white text-center py-5">
        <h1 class="display-4 fw-bold">Sistema de Gestión Lavacar Premium</h1>
        <p class="lead">
            Control total de clientes, vehículos y citas para autos de lujo.
        </p>
    </div>

    <!-- DASHBOARD CARDS -->
    <div class="container mt-5">
        <div class="row g-4">

            <!-- CLIENTES -->
            <div class="col-md-4">
                <div class="card shadow h-100 border-0">
                    <div class="card-body text-center">
                        <i class="bi bi-people-fill fs-1 text-primary"></i>
                        <h4 class="mt-3">Clientes</h4>
                        <p class="text-muted">
                            Gestión completa de clientes registrados.
                        </p>
                        <a asp-controller="Cliente" asp-action="Index"
                           class="btn btn-primary w-100">
                            Ir a Clientes
                        </a>
                    </div>
                </div>
            </div>

            <!-- VEHÍCULOS -->
            <div class="col-md-4">
                <div class="card shadow h-100 border-0">
                    <div class="card-body text-center">
                        <i class="bi bi-car-front-fill fs-1 text-success"></i>
                        <h4 class="mt-3">Vehículos</h4>
                        <p class="text-muted">
                            Administración de vehículos asociados a clientes.
                        </p>
                        <a asp-controller="Vehiculo" asp-action="Index"
                           class="btn btn-success w-100">
                            Ir a Vehículos
                        </a>
                    </div>
                </div>
            </div>

            <!-- CITAS -->
            <div class="col-md-4">
                <div class="card shadow h-100 border-0">
                    <div class="card-body text-center">
                        <i class="bi bi-calendar-check-fill fs-1 text-danger"></i>
                        <h4 class="mt-3">Citas</h4>
                        <p class="text-muted">
                            Control de citas de lavado y estado del servicio.
                        </p>
                        <a asp-controller="Cita" asp-action="Index"
                           class="btn btn-danger w-100">
                            Ir a Citas
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- FOOTER INFO -->
    <div class="container mt-5 mb-5 text-center text-muted">
        <hr />
        <p>
            Lavacar Premium © 2026 | Sistema desarrollado bajo arquitectura por capas.
        </p>
    </div>

</div>