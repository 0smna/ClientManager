@{
    ViewData["Title"] = "Vehículos";
}

<link href="~/css/site.css" rel="stylesheet" />

<div class="container mt-4">
    <h2>Gestión de Vehículos</h2>

    <button class="btn btn-primary mb-3" onclick="abrirModal()">Nuevo Vehículo</button>

    <table id="tablaVehiculos" class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Placa</th>
                <th>Marca</th>
                <th>Modelo</th>
                <th>ClienteId</th>
                <th>Acciones</th>
            </tr>
        </thead>
    </table>
</div>

<!-- MODAL -->
<div class="modal fade" id="modalVehiculo" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Vehículo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="Id" />

                <div class="mb-3">
                    <label>Placa</label>
                    <input type="text" id="Placa" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Marca</label>
                    <input type="text" id="Marca" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Modelo</label>
                    <input type="text" id="Modelo" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>ClienteId</label>
                    <input type="number" id="ClienteId" class="form-control" />
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-success" onclick="guardar()">Guardar</button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/Vehiculo.js" asp-append-version="true"></script>
}